<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="paperformat_sultan_delivery_slip" model="report.paperformat">
        <field name="name">Sultan Delivery Slip A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_spacing">0</field>
        <field name="header_line" eval="False"/>
        <field name="orientation">Portrait</field>
        <field name="dpi">90</field>
    </record>

    <record id="stock.action_report_delivery" model="ir.actions.report">
        <field name="paperformat_id" ref="sultan_stock.paperformat_sultan_delivery_slip"/>
    </record>

    <template id="sultan_delivery_layout">
        <t t-if="not o" t-set="o" t-value="doc"/>
        <div t-attf-class="article o_report_layout_standard o_company_#{o.company_id.id}_layout"
            t-att-data-oe-model="o and o._name"
            t-att-data-oe-id="o and o.id"
            t-att-data-oe-lang="o and o.env.context.get('lang')">
            <t t-raw="0"/>
        </div>
    </template>

    <template id="report_delivery_document_sultan" inherit_id="stock.report_delivery_document">
        <xpath expr="//t[@t-call='web.external_layout']" position="attributes">
            <attribute name="t-call">sultan_stock.sultan_delivery_layout</attribute>
        </xpath>
        <xpath expr="//t[@t-set='address']" position="replace">
            <t t-set="address"/>
        </xpath>
        <xpath expr="//t[@t-set='information_block']" position="replace">
            <t t-set="information_block"/>
        </xpath>
        <xpath expr="//div[hasclass('page')]" position="replace">
            <div class="page sultan-delivery-slip">
                <style type="text/css">
                    .sultan-delivery-slip {
                        font-size:10px;
                    }
                    .sultan-delivery-slip .sultan-static {
                        background:#DEDEDE !important;
                        font-weight:bold !important;
                    }
                    .sultan-delivery-slip .sultan-table {
                        width:100%;
                        table-layout:fixed;
                        margin-bottom:0;
                    }
                    .sultan-delivery-slip .sultan-table th,
                    .sultan-delivery-slip .sultan-table td {
                        border:1px solid #777777;
                        padding:2px 8px;
                        vertical-align:middle;
                    }
                    .sultan-delivery-slip .sultan-title {
                        border:1px solid #777777;
                        padding:3px 8px;
                        text-align:center;
                        font-size:13px;
                    }
                    .sultan-delivery-slip .sultan-value {
                        background:#FFFFFF !important;
                        font-weight:normal !important;
                    }
                    .sultan-delivery-slip .sultan-nowrap {
                        white-space:nowrap;
                    }
                    .sultan-delivery-slip address {
                        margin-bottom:0;
                    }
                </style>

                <t t-set="format_number" t-value="lambda x: int(x) if x == int(x) else x"/>
                <t t-set="delivery_partner" t-value="o.move_ids[:1].partner_id or o.partner_id"/>
                <t t-set="company" t-value="o.company_id.sudo()"/>

                <div class="row mt-0" style="border:1px solid #777777;margin:0 0 4px 0;">
                    <div class="col-4 pt-1 pb-1 text-left px-2">
                        <span t-if="company.name"><b><span t-esc="company.name"/></b><br/></span>
                        <span t-if="company.street"><span t-esc="company.street"/><br/></span>
                        <span t-if="company.street2"><span t-esc="company.street2"/><br/></span>
                        <span t-if="company.city or company.zip">
                            <span t-esc="company.city"/>
                            <span t-esc="company.zip"/><br/>
                        </span>
                        <span t-if="company.country_id"><span t-esc="company.country_id.name"/></span>
                    </div>
                    <div class="col-4 text-center d-flex justify-content-center align-items-center pt-1">
                        <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" alt="Logo"
                            style="width:100%;max-width:100%;object-fit:contain;height:80px;"/>
                    </div>
                    <div class="col-4 pt-1 pb-1 px-2" style="text-align:right;">
                        <span t-if="company.sh_name"><b><span t-esc="company.sh_name"/></b><br/></span>
                        <span t-if="company.sh_street"><span t-esc="company.sh_street"/><br/></span>
                        <span t-if="company.sh_street2"><span t-esc="company.sh_street2"/><br/></span>
                        <span t-if="company.sh_city or company.sh_zip">
                            <span t-esc="company.sh_city"/>
                            <span t-esc="company.sh_zip"/><br/>
                        </span>
                        <span t-if="company.sh_country_id"><span t-esc="company.sh_country_id"/></span>
                    </div>
                </div>

                <div class="row mt-1">
                    <div class="col-12 pl-0 pr-0">
                        <table class="table table-bordered sultan-table">
                            <colgroup>
                                <col style="width:25%;" />
                                <col style="width:10%;" />
                                <col style="width:8%;" />
                                <col style="width:14%;" />
                                <col style="width:12%;" />
                                <col style="width:13%;" />
                                <col style="width:8%;" />
                                <col style="width:10%;" />
                            </colgroup>
                            <tr>
                                <td colspan="8" class="sultan-static sultan-title">
                                    <span>سند التسليم / Delivery Slip</span>
                                </td>
                            </tr>
                            <tr>
                                <th colspan="2" class="sultan-static" style="text-align:left;">Customer / العميل</th>
                                <td colspan="4" class="sultan-static" style="text-align:right;">Delivery Information / بيانات التسليم</td>
                                <td colspan="2" class="sultan-static" style="text-align:center;">Barcode / الباركود</td>
                            </tr>
                            <tr>
                                <td colspan="2" rowspan="2" class="sultan-value" style="vertical-align:top;text-align:left;">
                                    <div t-if="delivery_partner"
                                         t-out="delivery_partner"
                                         t-options='{"widget": "contact", "fields": ["address", "name", "phone", "vat"], "no_marker": True, "phone_icons": True}'/>
                                    <div t-else="" t-out="o.company_id.partner_id"
                                         t-options='{"widget": "contact", "fields": ["address", "name", "phone", "vat"], "no_marker": True, "phone_icons": True}'/>
                                </td>
                                <td class="sultan-static" style="text-align:left;">Picking reference</td>
                                <td colspan="2" class="sultan-value" style="text-align:center;"><span t-field="o.name"/></td>
                                <td class="sultan-static" style="text-align:right;">رقم المستند</td>
                                <td colspan="2" rowspan="2" class="sultan-value" style="text-align:center;vertical-align:middle;">
                                    <img t-if="o.name"
                                         t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s&amp;humanreadable=1' % ('Code128', o.name, 230, 45)"
                                         style="max-width:105px;height:38px;"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="sultan-static" style="text-align:left;">Source Document</td>
                                <td colspan="2" class="sultan-value" style="text-align:center;"><span t-field="o.origin"/></td>
                                <td class="sultan-static" style="text-align:right;">المستند المرجعي</td>
                            </tr>
                        </table>
                    </div>
                </div>

                <div class="row mt-2">
                    <div class="col-12 pl-0 pr-0">
                        <table class="table table-bordered sultan-table">
                            <colgroup>
                                <col style="width:25%;" />
                                <col style="width:10%;" />
                                <col style="width:8%;" />
                                <col style="width:14%;" />
                                <col style="width:12%;" />
                                <col style="width:13%;" />
                                <col style="width:8%;" />
                                <col style="width:10%;" />
                            </colgroup>
                            <thead>
                                <tr>
                                    <th colspan="4" class="sultan-static" style="text-align:center;">Product<br/>المنتج</th>
                                    <th class="sultan-static" style="text-align:center;">Done<br/>الكمية</th>
                                    <th class="sultan-static" style="text-align:center;">UoM<br/>الوحدة</th>
                                    <th class="sultan-static" style="text-align:center;">Lot<br/>الدفعة</th>
                                    <th class="sultan-static" style="text-align:center;">Package<br/>الطرد</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="move_lines" t-value="o.move_ids.filtered(lambda move: move.product_uom_qty)"/>
                                <tr t-foreach="move_lines" t-as="move">
                                    <td colspan="4">
                                        <span t-field="move.product_id"/>
                                        <div t-if="move.description_picking and move.description_picking != move.product_id.name and move._get_report_description_picking()">
                                            <span t-out="move._get_report_description_picking()" t-options="{'widget': 'text'}"/>
                                        </div>
                                    </td>
                                    <td class="text-center sultan-nowrap"><span t-out="format_number(move.quantity)"/></td>
                                    <td class="text-center"><span t-field="move.product_uom" groups="uom.group_uom"/></td>
                                    <td class="text-center"></td>
                                    <td class="text-center"></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="row mt-4" style="page-break-inside:avoid;">
                    <div class="col-6 pl-0">
                        <table class="table table-bordered sultan-table">
                            <tr>
                                <td colspan="3" class="sultan-static" style="height:22px;text-align:center;background:#DEDEDE !important;font-weight:bold !important;">Receiver Information / بيانات المستلم</td>
                            </tr>
                            <tr>
                                <td class="sultan-static" style="width:34%;height:22px;text-align:left;background:#DEDEDE !important;font-weight:bold !important;">Receiver Name</td>
                                <td class="sultan-value" style="width:32%;height:22px;text-align:center;"><span t-field="o.receiver_name"/></td>
                                <td class="sultan-static" style="width:34%;height:22px;text-align:right;background:#DEDEDE !important;font-weight:bold !important;">اسم المستلم</td>
                            </tr>
                            <tr>
                                <td class="sultan-static" style="height:22px;text-align:left;background:#DEDEDE !important;font-weight:bold !important;">Receiver Phone</td>
                                <td class="sultan-value" style="height:22px;text-align:center;"><span t-field="o.receiver_phone"/></td>
                                <td class="sultan-static" style="height:22px;text-align:right;background:#DEDEDE !important;font-weight:bold !important;">هاتف المستلم</td>
                            </tr>
                            <tr>
                                <td class="sultan-static" style="height:22px;text-align:left;background:#DEDEDE !important;font-weight:bold !important;">Legal ID Number</td>
                                <td class="sultan-value" style="height:22px;text-align:center;"><span t-field="o.receiver_legal_id"/></td>
                                <td class="sultan-static" style="height:22px;text-align:right;background:#DEDEDE !important;font-weight:bold !important;">رقم الهوية</td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-6 pr-0">
                        <table class="table table-bordered sultan-table">
                            <tr>
                                <td class="sultan-static" style="height:22px;text-align:center;">Signature / التوقيع</td>
                            </tr>
                            <tr>
                                <td style="height:66px;text-align:center;vertical-align:middle;">
                                    <img t-if="o.signature" t-att-src="image_data_uri(o.signature)" style="max-height:40px;max-width:180px;"/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
