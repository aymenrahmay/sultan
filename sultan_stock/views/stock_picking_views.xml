<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_picking_form_sultan_receiver" model="ir.ui.view">
        <field name="name">stock.picking.form.sultan.receiver</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id'][1]" position="after">
                <field name="receiver_name" readonly="state in ['cancel', 'done']"/>
                <field name="receiver_phone" readonly="state in ['cancel', 'done']"/>
                <field name="receiver_legal_id" readonly="state in ['cancel', 'done']"/>
            </xpath>
        </field>
    </record>
</odoo>
