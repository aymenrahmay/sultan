<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="account_move_inherit_view_form" model="ir.ui.view">
        <field name="name">account.move.inherit.view.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <field name="payment_reference" position="after">
                <field name="sh_qr_code_img" widget="image" class="oe_avatar float-left"
                    invisible="state in ['draft','cancel']" />
                <!-- <field name="sh_qr_code_img" widget="image" class="oe_avatar float-left" attrs
                = "{'invisible' : [('state', 'in', ['draft','cancel'])]}"/> -->
                <field name="amount_in_words" invisible="1" />
                <field name="amount_in_words_ar" invisible="1" />
            </field>
            <xpath expr="//group[@id='header_left_group']/field[@name='partner_shipping_id']" position="after">
                <field name="receiver_name" invisible="move_type not in ('out_invoice', 'out_refund')" />
                <field name="receiver_phone" invisible="move_type not in ('out_invoice', 'out_refund')" />
                <field name="receiver_legal_id" invisible="move_type not in ('out_invoice', 'out_refund')" />
            </xpath>
            <xpath
                expr="//form/sheet/notebook/page/field[@name='invoice_line_ids']/list/field[@name='name']"
                position="after">
                <field name="line_tax_Amount" column_invisible="1" />
            </xpath>
        </field>
    </record>
</odoo>
