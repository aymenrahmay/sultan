<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="account.account_invoices" model="ir.actions.report">
        <field name="paperformat_id"
            ref="sh_electronic_invoice_qr_saudi_invoice.paperformat_custom_saudi" />
        <field name="attachment_use">False</field>
    </record>
    <template id="report_invoice_use_sultan_document" inherit_id="account.report_invoice" priority="99">
        <xpath expr="//t[@t-call='account.report_invoice_document']" position="attributes">
            <attribute name="t-if">o._get_name_invoice_report() == 'sh_electronic_invoice_qr_saudi_invoice.inherit_report_invoice_document'</attribute>
            <attribute name="t-call">sh_electronic_invoice_qr_saudi_invoice.inherit_report_invoice_document</attribute>
        </xpath>
    </template>

    <template id="inherit_report_invoice_document" inherit_id="account.report_invoice_document" primary="True" priority="99">
        <xpath expr="//t[@t-call='web.external_layout']" position="attributes">
            <attribute name="t-call">sh_electronic_invoice_qr_saudi_invoice.sultan_invoice_layout</attribute>
        </xpath>
        <xpath expr="//div[hasclass('row')][.//t[@t-set='address']]" position="replace">
            <t />
        </xpath>
        <xpath expr="//t[@t-set='layout_document_title']" position="replace">
            <t t-set="layout_document_title" />
        </xpath>
        <xpath expr="//div[hasclass('page')]" position="attributes">
            <attribute name="class" add="d-none" separator=" " />
        </xpath>

        <xpath expr="//div[hasclass('page')]" position="before">
            <t t-set="company" t-value="o.company_id.sudo() or res_company" />
            <div class="row mt-0" style="font-size: 13px;">
                <div class="col-12 col-sm-12 col-md-12 col-lg-12 col-xl-12 pl-0 pr-0">
                    <div class="row" style="border:1px solid #777777;margin:0;">
                        <div class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 pt-1 pb-1 text-left px-2">
                            <span t-if="company.name">
                                <b><span t-esc="company.name" /></b><br />
                            </span>
                            <span t-if="company.street">
                                <span t-esc="company.street" /><br />
                            </span>
                            <span t-if="company.street2">
                                <span t-esc="company.street2" /><br />
                            </span>
                            <span t-if="company.city or company.zip">
                                <span t-esc="company.city" />
                                <span t-esc="company.zip" /><br />
                            </span>
                            <span t-if="company.country_id">
                                <span t-esc="company.country_id.name" />
                            </span>
                        </div>

                        <div class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 text-center d-flex justify-content-center align-items-center pt-1">
                            <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" alt="Logo"
                                style="width:100%;max-width:100%;object-fit:contain;height:80px;" />
                        </div>

                        <div class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 pt-1 pb-1 px-2" style="text-align:right;">
                            <span t-if="company.sh_name">
                                <b><span t-esc="company.sh_name" /></b><br />
                            </span>
                            <span t-if="company.sh_street">
                                <span t-esc="company.sh_street" /><br />
                            </span>
                            <span t-if="company.sh_street2">
                                <span t-esc="company.sh_street2" /><br />
                            </span>
                            <span t-if="company.sh_city or company.sh_zip">
                                <span t-esc="company.sh_city" />
                                <span t-esc="company.sh_zip" /><br />
                            </span>
                            <span t-if="company.sh_country_id">
                                <span t-esc="company.sh_country_id" />
                            </span>
                        </div>
                    </div>

                    <div class="row" style="margin:0;">
                        <div class="col-6 col-sm-6 col-md-6 col-lg-6 col-xl-6 pl-0 pr-0"
                            style="border:1px solid #777777;border-top:0;">
                            <table class="table border-top-0 sh-label-table" style="margin-bottom:0;font-size: 12px;">
                                <tr>
                                    <td style="border-top:0;padding:1px 8px;">CR No.:</td>
                                    <td style="border-top:0;padding:1px 8px;">
                                        <span t-if="company.company_registry" t-esc="company.company_registry" />
                                    </td>
                                    <td style="border-top:0;padding:1px 2px;text-align:right;">رقم السجل التجاري</td>
                                </tr>
                            </table>
                        </div>

                        <div class="col-6 col-sm-6 col-md-6 col-lg-6 col-xl-6 pl-0 pr-0"
                            style="border:1px solid #777777;border-left:0;border-top:0;">
                            <table class="table border-top-0 sh-label-table" style="margin-bottom:0;font-size: 12px;">
                                <tr>
                                    <td style="border-top:0;padding:1px 8px;">VAT No.:</td>
                                    <td style="border-top:0;padding:1px 8px;">
                                        <span t-if="company.vat" t-esc="company.vat" />
                                    </td>
                                    <td style="border-top:0;padding:1px 2px;text-align:right;">الرقم الضريبي</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row border mt-1">
                <div class="col-12 col-sm-12 col-md-12 col-lg-12 col-xl-12 text-center pt-1 pb-1 sh-static-info"
                    style="background:#DEDEDE;border: 1px solid #777777;">
                    <t t-if="o.move_type == 'out_invoice'">
                        <h5 style="margin-bottom: 0px;font-weight: bold;font-size: 16px;">Tax Invoice / فاتورة ضريبية</h5>
                    </t>
                    <t t-if="o.move_type == 'out_refund'">
                        <h5 style="margin-bottom: 0px;font-weight: bold;font-size: 16px;">Credit Note / اشعار دائن</h5>
                    </t>
                    <t t-if="o.move_type == 'in_invoice'">
                        <h5 style="margin-bottom: 0px;font-weight: bold;font-size: 16px;">Bill /فاتورة مورد</h5>
                    </t>
                    <t t-if="o.move_type == 'out_refund'">
                        <h5 style="margin-bottom: 0px;font-weight: bold;font-size: 16px;">Debit Note / مرتجع فاتورة</h5>
                    </t>
                </div>
            </div>

            <div class="row mt-2">
                <div class="col-12 col-sm-12 col-md-12 col-lg-12 col-xl-12 pl-0 pr-0">
                    <table class="table table-bordered sh-label-table" style="font-size: 12px;table-layout:fixed;width:100%;">
                        <colgroup>
                            <col style="width:25%;" />
                            <col style="width:10%;" />
                            <col style="width:8%;" />
                            <col style="width:14%;" />
                            <col style="width:12%;" />
                            <col style="width:13%;" />
                            <col style="width:8%;" />
                            <col style="width:10%;" />
                        </colgroup>
                        <tr style="background:#DEDEDE;padding:1px">
                                <th colspan="3" scope="row" style="font-weight: bold;font-size: 13px; text-align: left;padding: 2px 8px; border:1px solid #777777;border-right:0">Customer / العميل</th>
                                <td colspan="3" style="font-weight: bold;font-size: 13px; text-align: right;padding: 2px 8px;border:1px solid #777777; border-left:0;">Invoice informations / بيانات الفاتورة</td>
                                <td colspan="2" style="font-weight: bold;font-size: 13px; text-align: center;padding: 2px 8px;border:1px solid #777777; border-left:0;">QR</td>
                        </tr>
                        <tr>
                            <td colspan="3" rowspan="5" style="text-align: left;vertical-align:top;padding: 2px 8px; border:1px solid #777777;background:#FFFFFF !important;font-weight:normal !important;">
                                <address t-field="o.partner_id" t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": True}' />
                                <div t-if="o.partner_id.vat" class="mt16">
                                    <t t-esc="o.company_id.country_id.vat_label or 'TIN'" />: <span t-field="o.partner_id.vat" /></div>
                            </td>
                            <td style="text-align:left;padding:2px 8px;border:1px solid #777777;background:#DEDEDE !important;font-weight:bold !important;">Invoice Number</td>
                            <td style="text-align:center;padding:2px 8px;border:1px solid #777777;background:#FFFFFF !important;font-weight:normal !important;"><span t-field="o.name" /></td>
                            <td style="text-align:right;padding:2px 8px;border:1px solid #777777;background:#DEDEDE !important;font-weight:bold !important;">رقم الفاتورة</td>
                            <td colspan="2" rowspan="5" style="text-align:center;vertical-align:middle;padding:2px 8px;border:1px solid #777777; border-left:0;background:#FFFFFF !important;">
                                <t t-if="o.sh_qr_code_img">
                                    <img t-att-src="image_data_uri(o.sh_qr_code_img)"
                                        style="height:85px; width:85px; border:0;" />
                                </t>
                            </td>
                        </tr>
                        <tr>
                            <td style="text-align:left;padding:2px 8px;border:1px solid #777777;background:#DEDEDE !important;font-weight:bold !important;">Invoice Date</td>
                            <td style="text-align:center;padding:2px 8px;border:1px solid #777777;background:#FFFFFF !important;font-weight:normal !important;"><span t-field="o.invoice_date" /></td>
                            <td style="text-align:right;padding:2px 8px;border:1px solid #777777;background:#DEDEDE !important;font-weight:bold !important;">التاريخ</td>
                        </tr>
                        <tr>
                            <td style="text-align:left;padding:2px 8px;border:1px solid #777777;background:#DEDEDE !important;font-weight:bold !important;">Invoice Due Date</td>
                            <td style="text-align:center;padding:2px 8px;border:1px solid #777777;background:#FFFFFF !important;font-weight:normal !important;"><span t-field="o.invoice_date_due" /></td>
                            <td style="text-align:right;padding:2px 8px;border:1px solid #777777;background:#DEDEDE !important;font-weight:bold !important;">تاريخ الإستحقاق</td>
                        </tr>
                        <tr>
                            <td style="text-align:left;padding:2px 8px;border:1px solid #777777;background:#DEDEDE !important;font-weight:bold !important;">Salesperson</td>
                            <td style="text-align:center;padding:2px 8px;border:1px solid #777777;background:#FFFFFF !important;font-weight:normal !important;"><span t-field="o.user_id" /></td>
                            <td style="text-align:right;padding:2px 8px;border:1px solid #777777;background:#DEDEDE !important;font-weight:bold !important;">مندوب المبيعات</td>
                        </tr>
                        <tr>
                            <td style="text-align:left;padding:2px 8px;border:1px solid #777777;background:#DEDEDE !important;font-weight:bold !important;">Payment Terms</td>
                            <td style="text-align:center;padding:2px 8px;border:1px solid #777777;background:#FFFFFF !important;font-weight:normal !important;"><span t-field="o.invoice_payment_term_id" /></td>
                            <td style="text-align:right;padding:2px 8px;border:1px solid #777777;background:#DEDEDE !important;font-weight:bold !important;">شروط الدفع</td>
                        </tr>

                    </table>
                </div>
            </div>
            <div class="row">
                <div class="col-12 col-sm-12 col-md-12 col-lg-12 col-xl-12 pl-0 pr-0">
                    <table class="table table-bordered sh-line-items" style="font-size: 12px;table-layout:fixed;width:100%;">
                        <colgroup>
                            <col style="width:25%;" />
                            <col style="width:10%;" />
                            <col style="width:8%;" />
                            <col style="width:14%;" />
                            <col style="width:12%;" />
                            <col style="width:13%;" />
                            <col style="width:8%;" />
                            <col style="width:10%;" />
                        </colgroup>
                        <tr style="background:#DEDEDE;">
                            <th scope="row" style=" font-weight: bold;font-size: 13px; border:1px solid #777777;text-align: center;">Goods and services<br /> تفاصيل السلع و الخدمات </th>
                            <th scope="row" style="font-weight: bold;font-size: 13px; border:1px solid #777777;text-align: center;">Unit Price<br /> سعر الوحدة </th>
                            <th scope="row" style="font-weight: bold;font-size: 13px; border:1px solid #777777;text-align: center;"> Quantity<br /> كمية </th>
                            <th scope="row" style="font-weight: bold;font-size: 13px; border:1px solid #777777;text-align: center;">Taxable Amount<br /> المبلغ الخاضع للضريبة </th>
                            <th scope="row" style="font-weight: bold;font-size: 13px; border:1px solid #777777;text-align: center;"> Discount<br /> خصم </th>
                            <th scope="row" style="font-weight: bold;font-size: 13px; border:1px solid #777777;text-align: center;">Tax Rate<br /> نسبة الضريبة </th>
                            <th scope="row" style="font-weight: bold;font-size: 13px; border:1px solid #777777;text-align: center;">Tax Amount<br /> قيمة الضريبة </th>
                            <th scope="row" style="font-weight: bold;font-size: 13px; border:1px solid #777777;text-align: center;">Subtotal (Including VAT)<br /> الإجمالي مع الضريبة </th>
                        </tr>

                        <t t-set="lines"
                            t-value="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)" />

                        <t t-foreach="lines" t-as="line">

                            <tr>
                                <td style="padding: 2px 10px;border:1px solid #777777">
                                    <span t-esc="line.name" />
                                    <br />
                                </td>

                                <td t-esc="line.price_unit"
                                    t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                                    class="text-center"
                                    style="padding: 2px 2px;border:1px solid #777777">

                                </td>

                                <td class="text-center"
                                    style="padding: 2px 2px;border:1px solid #777777">
                                    <t t-esc="line.quantity" /><![CDATA[&nbsp;]]>
                                    <t t-if="line.product_uom_id">
                                        <t t-esc="line.product_uom_id.name" />
                                    </t>
                                </td>

                                <td t-esc="line.taxable_amount"
                                    t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                                    class="text-center"
                                    style="padding: 2px 2px;border:1px solid #777777">

                                </td>

                                <td class="text-center"
                                    style="padding: 2px 2px;border:1px solid #777777">
                                    <t t-esc="line.discount" /> % </td>

                                <td class="text-center"
                                    style="padding: 2px 2px;border:1px solid #777777">
                                    <t t-foreach="line.tax_ids" t-as="tax">
                                        <t t-esc="tax.amount" /> % </t>
                                </td>

                                <td t-esc="line.line_tax_Amount"
                                    t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                                    class="text-center"
                                    style="padding: 2px 2px;border:1px solid #777777">

                                </td>

                                <td t-esc="line.price_subtotal + line.line_tax_Amount"
                                    t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                                    class="text-center"
                                    style="padding: 2px 8px;border:1px solid #777777">

                                </td>
                            </tr>
                        </t>
                    </table>
                </div>
            </div>

            <div class="row mt-2 border" style="page-break-inside: avoid;">
                <div class="col-12 col-sm-12 col-md-12 col-lg-12 col-xl-12 sh-static-info"  style="background:#DEDEDE; border: 1px solid #777777; padding:0px 10px;">
                    <span style="margin-bottom: 1px;font-weight: bold;font-size: 13px;">Total Amounts </span>
                    <span style="margin-bottom: 1px;font-weight: bold;font-size: 13px;float:right">المبلغ الإجمالي  </span>
                </div>
            </div>

            <div class="row">
                <div class="col-12 col-sm-12 col-md-12 col-lg-12 col-xl-12 pl-0 pr-0">
                    <table class="table table-bordered sh-total-table" style="font-size: 12px;">
                        <tr>
                            <th scope="row"
                                style="text-align: Center;padding: 2px 10px;  border: 1px solid #777777; text-align:left;">Total
                                (Excluding VAT)</th>
                            <td
                                style="text-align: Center;padding: 2px 2px;  border: 1px solid #777777; border-left:0;">الإجمالي
                                (باستثناء ضريبة القيمة المضافة)
                            </td>
                            <td
                                style="text-align: Center;padding: 2px 2px;  border: 1px solid #777777; text-align:right; border-left:0;"
                                t-esc="o.amount_untaxed + (o.amount_move_undiscounted - o.amount_untaxed)"
                                t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                                class="border-left-0">

                            </td>
                        </tr>

                        <tr>
                            <th scope="row"
                                style="text-align: Center;padding: 2px 10px; text-align:left; border: 1px solid #777777;">
                                Discount</th>
                            <td
                                style="text-align: Center;padding: 2px 2px; border: 1px solid #777777; border-left:0;">
                                خصم
                            </td>
                            <td
                                style="text-align: Center;padding: 2px 2px; border: 1px solid #777777; border-left:0; text-align:right;"
                                t-esc="o.amount_move_undiscounted - o.amount_untaxed"
                                t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                                class="border-left-0">

                            </td>
                        </tr>
                        <tr>
                            <th scope="row"
                                style="text-align: Center;padding: 2px 10px; text-align:left; border: 1px solid #777777;">Total
                                VAT</th>
                            <td
                                style="text-align: Center;padding: 2px 2px; border: 1px solid #777777; border-left:0;">
                                إجمالي ضريبة القيمة المضافة
                            </td>
                            <td
                                style="text-align: Center;padding: 2px 2px; border: 1px solid #777777; border-left:0; text-align:right;"
                                t-esc="o.amount_tax"
                                t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                                class="border-left-0">

                            </td>
                        </tr>
                        <tr>
                            <th scope="row"
                                style="text-align: Center;padding: 2px 10px; text-align:left; border: 1px solid #777777;">Total
                                Inoivce total amount (Incl Tax)</th>
                            <td
                                style="text-align: Center;padding: 2px 2px; border: 1px solid #777777; border-left:0;">
                                إحمالي الفاتورة مع الضريبة
                            </td>
                            <td
                                style="text-align: Center;padding: 2px 2px; border: 1px solid #777777; border-left:0; text-align:right;"
                                t-esc="o.amount_total_signed"
                                t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                                class="border-left-0">

                            </td>
                        </tr>
                    </table>
                </div>
            </div>
            <div class="row mt-1 border"
                style="font-size: 12px; margin-top:2px; page-break-inside: avoid; ">
                <div class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 sh-static-info"
                    style="background:#DEDEDE; border:1px solid #777777; ">
                    <span
                        style="margin-bottom: 0px;font-weight: bold;font-size: 13px; padding:0px 10px; text-transform:capitalized;">Invoiced
                        Amount
                    </span>
                </div>
                <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8"
                    style=" border:1px solid #777777;border-left:0px;">
                    <span style="margin-bottom: 0px;font-size: 13px; padding:2px 0px;">
                        <t t-esc="o.amount_in_words" />
                    </span>
                </div>
            </div>
            <div class="row mt-1 border" style="font-size: 12px; margin-bottom:5px; ">
                <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8"
                    style="border:1px solid #777777;">
                    <span
                        style="margin-bottom: 0px;font-size: 13px;text-align: right;padding:2px 0px;float:right">
                        <t t-esc="o.amount_in_words_ar" />
                    </span>
                </div>
                <div class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 sh-static-info"
                    style="background:#DEDEDE; border:1px solid #777777; border-left:0px;">
                    <span
                        style="margin-bottom: 0px;font-weight: bold;font-size: 13px;text-align: right;padding:2px 0px;">المبلغ
                        المفوتر
                    </span>
                </div>
            </div>

             <t groups="stock_account.group_lot_on_invoice">
                <t t-set="lot_values" t-value="o._get_invoiced_lot_values()" />
                <div t-if="lot_values" class="row mt-2" style="page-break-inside: avoid;">
                    <div class="col-12 col-sm-12 col-md-12 col-lg-12 col-xl-12 pl-0 pr-0">
                        <table class="table table-bordered" name="invoice_snln_table" style="font-size: 12px;table-layout:fixed;width:100%;">
                            <colgroup>
                                <col style="width:50%;" />
                                <col style="width:20%;" />
                                <col style="width:30%;" />
                            </colgroup>
                            <thead>
                                <tr style="background:#DEDEDE;">
                                    <th scope="row" style="font-weight:bold;font-size: 13px;border:1px solid #777777;text-align:center;">Product<br />المنتج</th>
                                    <th scope="row" style="font-weight:bold;font-size: 13px;border:1px solid #777777;text-align:center;">Quantity<br />الكمية</th>
                                    <th scope="row" style="font-weight:bold;font-size: 13px;border:1px solid #777777;text-align:center;">Serial / Lot Number<br />الرقم التسلسلي / الدفعة</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="lot_values" t-as="snln_line">
                                    <td style="padding:2px 8px;border:1px solid #777777;">
                                        <t t-esc="snln_line['product_name']" />
                                    </td>
                                    <td style="padding:2px 8px;border:1px solid #777777;text-align:center;">
                                        <t t-esc="snln_line['quantity']" />
                                        <t t-esc="snln_line['uom_name']" groups="uom.group_uom" />
                                    </td>
                                    <td style="padding:2px 8px;border:1px solid #777777;text-align:center;">
                                        <t t-esc="snln_line['lot_name']" />
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </t>

            <div t-if="o.narration" class="row mt-2" style="page-break-inside: avoid;">
                <div class="col-12 col-sm-12 col-md-12 col-lg-12 col-xl-12 pl-0 pr-0">
                    <table class="table table-bordered sultan-table" style="font-size: 12px;margin-bottom:0;">
                        <tr style="background:#DEDEDE;">
                            <td class="sultan-static" style="width:100%;font-weight:bold;font-size: 13px;border:1px solid #777777;text-align:left;padding:2px 8px;">
                                Terms and Conditions الشروط و الأحكام
                            </td>
                        </tr>
                        <tr>
